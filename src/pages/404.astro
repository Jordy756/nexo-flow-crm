---
import Background from "@components/layout/Background.astro";
import Footer from "@components/layout/Footer.astro";
import Header from "@components/layout/Header.astro";
import Link from "@components/ui/Link.astro";
import Layout from "@layouts/Layout.astro";

const title = "404 | Página no encontrada";
const description = "La página que buscas no existe.";
---

<Layout title={title} description={description}>
  <Background />
  <Header />
  <main class="flex-1 min-h-[calc(100vh-350px)] flex items-center justify-center">
    <section class="flex flex-col items-center gap-8">
      <h1 class="sr-only">404 — Página no encontrada</h1>
      <p aria-hidden="true" class="text-9xl font-bold md:text-[20rem] sm:text-[15rem] xl:text-[25rem]">404</p>
      <Link href="/">Volver al inicio</Link>
    </section>
  </main>
  <Footer />
</Layout>
