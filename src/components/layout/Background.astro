---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<video
  class:list={["fixed top-0 left-0 w-full h-screen object-cover -z-10", className]}
  poster="/images/background_poster_img.webp"
  muted
  autoplay
  loop
>
  <source src="/videos/hero.mp4" />
</video>
