---
import type { SiteData } from "@scripts/config/site.types";

interface Props {
  data: SiteData;
}

const { data } = Astro.props;
---

<footer class="w-[min(var(--max-width),100%)] bg-red-400">
  <section
    class="surface-glass flex flex-col items-start justify-between gap-4 rounded-2xl px-6 py-5 md:flex-row md:items-center"
  >
    <p class="text-sm text-slate-300">{data.footer.legal}</p>
    <ul class="flex flex-wrap items-center gap-4 text-sm text-slate-400" role="list">
      {
        data.footer.links.map((item) => (
          <li>
            <a href={item.href} class="transition hover:text-cyan-200">
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</footer>
