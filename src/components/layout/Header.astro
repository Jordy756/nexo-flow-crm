---
import type { SiteData } from "@scripts/config/site.types";
import Link from "@components/ui/Link.astro";

interface Props {
  data: SiteData;
}

const { data } = Astro.props;
---

<header class="sticky top-0 left-0 flex justify-center w-full z-40">
  <nav class="flex items-center justify-between gap-4 w-[min(var(--max-width),100%)] px-4 py-4">
    <a href="/#" class="">{data.brand.name}</a>
    <div class="flex items-center gap-16 p-2 pl-6 bg-glass rounded-full">
      <ul class="flex items-center gap-16 font-medium">
        {
          data.nav.map((item) => (
            <li>
              <a class="" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <Link href={data.brand.primaryCta.href}>{data.brand.primaryCta.label}</Link>
    </div>
    <span></span>
  </nav>
</header>
