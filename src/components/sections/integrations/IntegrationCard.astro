---
interface Props {
  integration: ((props: Record<string, unknown>) => unknown) | null;
}

const { integration } = Astro.props;
const Icon = integration;
---

<article class:list={["flex rotate-45 rounded-md bg-glass p-8", integration === null && "opacity-60"]}>
  {Icon ? <Icon width={48} height={48} class="-rotate-45" /> : <div class="h-12 w-12" />}
</article>
