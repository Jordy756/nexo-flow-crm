---
import Container from "@components/ui/Container.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import type { SiteData } from "@scripts/config/site.types";
import IntegrationCard from "./IntegrationCard.astro";
import WorkflowStep from "./WorkflowStep.astro";

interface Props {
  data: SiteData;
}

const { data } = Astro.props;
---

<section id="integrations" class="py-14 sm:py-20">
  <Container>
    <SectionHeading
      eyebrow="Integraciones"
      title="Canales nativos, datos limpios y seguimiento orquestado"
      description="Conecta APIs reales y define una secuencia operativa clara para tu equipo comercial y de retencion."
    />

    <div class="mt-10 grid gap-4 lg:grid-cols-[1fr_0.95fr]">
      <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
        {data.integrations.map((integration) => <IntegrationCard integration={integration} />)}
      </div>

      <article class="surface-glass-strong rounded-2xl p-6">
        <header>
          <p class="text-xs uppercase tracking-[0.22em] text-cyan-100">Workflow base</p>
        </header>
        <ol class="mt-5 space-y-5">
          {data.workflow.map((step, index) => <WorkflowStep step={step} index={index} />)}
        </ol>
      </article>
    </div>
  </Container>
</section>
