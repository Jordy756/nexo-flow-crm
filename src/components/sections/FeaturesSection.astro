---
import Container from "@components/ui/Container.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import type { SiteData } from "@scripts/config/site.types";

interface Props {
  data: SiteData;
}

const { data } = Astro.props;
---

<section id="features" class="py-14 sm:py-20">
  <Container>
    <SectionHeading
      eyebrow="Core capabilities"
      title="Todo lo necesario para un CRM operativo desde el dia uno"
      description="Disenado para equipos que necesitan velocidad, trazabilidad y contexto compartido en cada contacto."
    />

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {
        data.featureGroups.map((group) => (
          <article class="btn-glass rounded-2xl p-6">
            <h3 class="text-xl font-semibold text-white">{group.title}</h3>
            <p class="mt-2 text-sm text-violet-200">{group.subtitle}</p>
            <ul class="mt-4 space-y-2 text-sm leading-relaxed text-slate-300">
              {group.items.map((item) => (
                <li>• {item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </Container>
</section>
