---
import StarsIcon from "@components/icons/Stars.astro";
import Badge from "@components/ui/Badge.astro";
import Link from "@components/ui/Link.astro";
import { basics } from "@data/data.json";
import { Image } from "astro:assets";

const { badge, title, description } = basics;
const requestDemoLink =
  "https://wa.me/50688888888?text=Hola%20NexoFlow%2C%20quiero%20saber%20m%C3%A1s%20sobre%20el%20CRM";
---

<section class="flex w-[min(var(--max-width),100%)] flex-col items-center gap-8 px-4 md:gap-32">
  <article class="flex flex-col items-center gap-8">
    <Badge>
      <StarsIcon width={16} class="text-neutral-50" />
      {badge}
    </Badge>
    <div class="flex flex-col items-center gap-2 text-center">
      <h1 class="sr-only">CRM con WhatsApp y Email para equipos de ventas</h1>
      <h2 class="flex max-w-[15ch] flex-col text-5xl font-bold sm:text-7xl">
        {title}
      </h2>
      <p class="max-w-[50ch] font-normal">{description}</p>
    </div>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <Link href="/#plans" variant="secondary" class="flex-1">Ver planes</Link>
      <Link href={requestDemoLink} target="_blank" class="flex-1"> Solicitar demo </Link>
    </div>
  </article>
  <figure
    class="flex w-full flex-col supports-scroll-timeline:animate-hero-scale supports-scroll-timeline:[animation-timeline:scroll()] supports-scroll-timeline:animate-range-[0_500px]"
  >
    <Image
      src="/images/hero_dashboard_img.webp"
      width={1564}
      height={862}
      alt="Vista de dashboard CRM con pipeline, bandeja de mensajes y actividad de equipo"
      class="h-auto w-full rounded-2xl bg-glass"
      loading="eager"
    />
  </figure>
</section>
