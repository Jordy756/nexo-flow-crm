---
import StarsIcon from "@components/icons/Stars.astro";
import Badge from "@components/ui/Badge.astro";
import Link from "@components/ui/Link.astro";
import { basics } from "@data/data.json";
import { Image } from "astro:assets";

const { badge, title, description } = basics;
const requestDemoLink = "https://jordy756-minimalist-portfolio.vercel.app/";
---

<section
  class="-mt-24 flex min-h-[calc(100vh-78px-2rem)] w-[min(var(--max-width),100%)] flex-col items-center gap-8 px-4 sm:mt-0 sm:min-h-[calc(100vh-78px-8rem)] sm:gap-32 lg:min-h-[calc(100vh-94px-8rem)]"
>
  <article class="flex flex-1 animate-fade-in-up flex-col items-center justify-center gap-8 animate-delay-3000">
    <Badge>
      <StarsIcon width={16} class="text-neutral-50" />
      {badge}
    </Badge>
    <div class="flex flex-col items-center gap-2 text-center">
      <h1 class="sr-only">CRM con WhatsApp y Email para equipos de ventas</h1>
      <h2 class="flex max-w-[15ch] flex-col text-5xl font-bold sm:text-7xl">
        {title}
      </h2>
      <p class="max-w-[50ch] font-normal">{description}</p>
    </div>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <Link href="/#plans" variant="secondary" class="flex-1">Ver Planes</Link>
      <Link href={requestDemoLink} target="_blank" class="flex-1">Solicitar Demo</Link>
    </div>
  </article>
  <figure class="flex h-full w-full animate-fade-in-up flex-col animate-delay-3400">
    <Image
      src="https://res.cloudinary.com/dd3hdnfqi/image/upload/v1776986631/hero_dashboard_img_dg8xkp.webp"
      width={1564}
      height={862}
      alt="Vista de dashboard CRM con pipeline, bandeja de mensajes y actividad de equipo"
      class="h-auto w-full rounded-xl bg-glass sm:supports-scroll-timeline:animate-hero-scale sm:supports-scroll-timeline:animate-range-[0_500px] sm:supports-scroll-timeline:timeline-scroll"
      loading="eager"
    />
  </figure>
</section>
