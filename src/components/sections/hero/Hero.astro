---
import type { SiteData } from "@scripts/config/site.types";
import Link from "@components/ui/Link.astro";
import Section from "@components/layout/Section.astro";
import { Image } from "astro:assets";
import Badge from "@components/ui/Badge.astro";
import FeatureIcon from "@components/icons/Feature.astro";

interface Props {
  data: SiteData;
}

const { data } = Astro.props;
---

<Section id="hero" class="flex flex-col gap-12">
  <article class="flex flex-col gap-4 items-center text-center">
    <Badge>
      <FeatureIcon width={16} class="text-neutral-50" />
      New feature for you!
    </Badge>
    <h2 class="text-7xl font-semibold max-w-[20ch]">Customers ask on chat. Call for details. Confirm by email. Can you keep up?</h2>
    <p class="max-w-[70ch]">
      Most platforms can't. Respond.io unifies all customer touchpoints and CRMs in a team inbox with AI Agents and
      native lead management so your conversations never break — even when customers switch channels.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <Link href={data.brand.secondaryCta.href} variant="secondary">{data.brand.secondaryCta.label}</Link>
      <Link href={data.brand.primaryCta.href}>{data.brand.primaryCta.label}</Link>
    </div>
  </article>

  <figure class="flex w-full">
    <Image
      src="/images/hero_dashboard_img.png"
      width={1160}
      height={650}
      alt="Vista de dashboard CRM con pipeline, bandeja de mensajes y actividad de equipo"
      class="rounded-2xl w-full"
      loading="eager"
    />
  </figure>
</Section>
