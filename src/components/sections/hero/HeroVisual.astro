---
interface Props {
  notes: string[];
}

const { notes } = Astro.props;
---

<figure class="relative">
  <div class="surface-glass-strong rounded-[1.75rem] p-4 sm:p-5">
    <img
      src="/hero-dashboard.svg"
      alt="Vista de dashboard CRM con pipeline, bandeja de mensajes y actividad de equipo"
      class="rounded-2xl"
      loading="eager"
    />
  </div>

  <aside class="surface-glass float-soft absolute -bottom-8 -left-4 max-w-xs rounded-2xl p-4 sm:-left-8">
    <img src="/hero-chat.svg" alt="Vista de seguimiento conversacional multicanal" class="rounded-xl" loading="lazy" />
    <ul class="mt-3 space-y-2 text-xs text-slate-200" role="list">
      {notes.map((note) => <li>• {note}</li>)}
    </ul>
  </aside>
</figure>
