---
import Container from "@components/ui/Container.astro";
import Button from "@components/ui/Button.astro";
import type { SiteData } from "@scripts/config/site.types";

interface Props {
  data: SiteData;
}

const { data } = Astro.props;
---

<section id="hero" class="relative overflow-hidden pb-14 pt-14 sm:pb-20 sm:pt-20">
  <Container>
    <div class="grid items-center gap-12 lg:grid-cols-[1.02fr_0.98fr]">
      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-violet-300/90">{data.hero.eyebrow}</p>
        <h1 class="mt-4 max-w-xl text-4xl font-semibold leading-tight text-white sm:text-5xl lg:text-6xl">
          {data.hero.title}
          <span class="text-gradient block">{data.hero.highlight}</span>
        </h1>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-slate-300 sm:text-lg">
          {data.hero.description}
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={data.brand.primaryCta.href} size="lg">{data.brand.primaryCta.label}</Button>
          <Button href={data.brand.secondaryCta.href} variant="secondary" size="lg">
            {data.brand.secondaryCta.label}
          </Button>
        </div>

        <dl class="mt-8 grid max-w-xl gap-3 sm:grid-cols-3">
          {
            data.hero.stats.map((stat) => (
              <div class="btn-glass rounded-xl p-4">
                <dt class="text-xs uppercase tracking-[0.12em] text-slate-400">{stat.label}</dt>
                <dd class="mt-1 text-lg font-semibold text-white">{stat.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="relative">
        <div class="btn-glass-strong relative rounded-3xl p-4 sm:p-5">
          <img
            src="/hero-dashboard.svg"
            alt="Vista del dashboard CRM con metricas y bandeja de conversaciones"
            class="w-full rounded-2xl"
            loading="eager"
          />
        </div>

        <div class="btn-glass floating-card absolute -bottom-8 -left-4 max-w-xs rounded-2xl p-4 sm:-left-8">
          <img
            src="/hero-chat.svg"
            alt="Panel de seguimiento por WhatsApp y email"
            class="w-full rounded-xl"
            loading="lazy"
          />
          <ul class="mt-3 space-y-2 text-xs text-slate-200">
            {data.hero.visualNotes.map((note) => <li>• {note}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </Container>
</section>
