---
import Container from "@components/ui/Container.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import type { SiteData } from "@scripts/config/site.types";

interface Props {
  data: SiteData;
}

const { data } = Astro.props;
---

<section id="integrations" class="py-14 sm:py-20">
  <Container>
    <SectionHeading
      eyebrow="Integraciones externas"
      title="Canales reales, sin workarounds"
      description="Conecta WhatsApp y correo como canales nativos y dispara flujos de seguimiento con reglas claras."
    />

    <div class="mt-10 grid gap-4 lg:grid-cols-[1fr_0.9fr]">
      <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
        {
          data.integrations.map((integration) => (
            <article class="btn-glass rounded-2xl p-5">
              <p class="text-xs uppercase tracking-[0.2em] text-violet-300">{integration.tag}</p>
              <h3 class="mt-2 text-lg font-semibold text-white">{integration.name}</h3>
              <p class="mt-2 text-sm text-slate-300">{integration.description}</p>
            </article>
          ))
        }
      </div>

      <div class="btn-glass-strong rounded-2xl p-6">
        <p class="text-xs uppercase tracking-[0.22em] text-violet-200">Workflow base</p>
        <ol class="mt-5 space-y-5">
          {
            data.workflow.map((step, index) => (
              <li class="flex gap-3 text-sm text-slate-200">
                <span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full border border-violet-300/40 bg-violet-500/20 text-xs text-violet-100">
                  {index + 1}
                </span>
                <span>{step}</span>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </Container>
</section>
