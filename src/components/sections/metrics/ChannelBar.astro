---
interface Props {
  label: string;
  value: number;
  className: string;
}

const { label, value, className } = Astro.props;
---

<div>
  <div class="mb-1 flex items-center justify-between text-xs text-slate-300">
    <span>{label}</span>
    <span>{value}%</span>
  </div>
  <div class="h-2 rounded-full bg-white/10">
    <div class:list={["h-full rounded-full", className]} style={`width: ${value}%`}></div>
  </div>
</div>
