---
import type { Kpi } from "@scripts/config/site.types";

interface Props {
  kpi: Kpi;
}

const { kpi } = Astro.props;
---

<article class="surface-glass rounded-2xl p-5">
  <p class="text-xs uppercase tracking-[0.15em] text-slate-400">{kpi.label}</p>
  <p class="mt-3 text-3xl font-semibold text-slate-100">{kpi.value}</p>
  <p class="mt-2 text-sm text-emerald-300">{kpi.trend}</p>
</article>
