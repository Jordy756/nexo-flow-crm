---
import Container from "@components/ui/Container.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import type { SiteData } from "@scripts/config/site.types";
import KpiCard from "./KpiCard.astro";
import ChannelBar from "./ChannelBar.astro";

interface Props {
  data: SiteData;
}

const { data } = Astro.props;
---

<section id="metrics" class="py-14 sm:py-20">
  <Container>
    <SectionHeading
      eyebrow="Metricas y analitica"
      title="Panel unico para decisiones comerciales"
      description="Visualiza KPIs clave para operaciones de captacion y seguimiento con lectura inmediata."
    />

    <div class="mt-10 grid gap-4 lg:grid-cols-[1fr_1.05fr]">
      <div class="grid gap-4 sm:grid-cols-2">
        {data.kpis.map((kpi) => <KpiCard kpi={kpi} />)}
      </div>

      <aside class="surface-glass-strong rounded-2xl p-6">
        <h3 class="text-sm font-medium text-slate-200">Rendimiento por canal</h3>
        <div class="mt-5 space-y-4">
          <ChannelBar label="WhatsApp" value={72} className="bg-gradient-to-r from-cyan-400 via-sky-300 to-cyan-200" />
          <ChannelBar label="Email" value={61} className="bg-gradient-to-r from-blue-500 via-sky-400 to-blue-200" />
          <ChannelBar
            label="Recordatorios auto"
            value={84}
            className="bg-gradient-to-r from-lime-300 via-emerald-300 to-cyan-300"
          />
        </div>
      </aside>
    </div>
  </Container>
</section>
