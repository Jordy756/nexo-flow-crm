---
import type { FaqItem } from "@scripts/config/site.types";

interface Props {
  item: FaqItem;
}

const { item } = Astro.props;
---

<details class="surface-glass rounded-2xl p-5">
  <summary class="cursor-pointer list-none text-base font-medium text-slate-100">{item.q}</summary>
  <p class="mt-3 text-sm leading-relaxed text-slate-300">{item.a}</p>
</details>
