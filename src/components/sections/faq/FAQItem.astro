---
interface Props {
  question: string;
  answer: string;
  name?: string;
}

const { name, question, answer } = Astro.props;
---

<details name={name} class="border-b border-neutral-50">
  <summary class="flex items-center justify-between gap-4 cursor-pointer px-4 py-4 text-lg font-medium">
    {question}
    <div
      class="relative w-4 h-px bg-neutral-50 before:absolute before:top-0 before:w-full before:h-px before:bg-neutral-50 before:rotate-90"
    >
    </div>
  </summary>
  <div class="px-8 pb-4 flex justify-end">
    <div class="w-1/2">
      <p class="">{answer}</p>
    </div>
  </div>
</details>
