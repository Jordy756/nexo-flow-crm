---
import Container from "@components/ui/Container.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import type { SiteData } from "@scripts/config/site.types";
import FaqItem from "./faqItem.astro";

interface Props {
  data: SiteData;
}

const { data } = Astro.props;
---

<section id="faq" class="py-14 sm:py-20">
  <Container>
    <SectionHeading
      eyebrow="FAQ"
      title="Preguntas frecuentes"
      description="Respuestas rapidas sobre implementacion y operacion del CRM."
    />

    <div class="mt-10 space-y-4">{data.faq.map((item) => <FaqItem item={item} />)}</div>
  </Container>
</section>
