---
import { features } from "@data/data.json";
import FeatureCard from "./FeatureCard.astro";
---

<section
  id="features"
  class="relative flex flex-col items-center gap-20 px-4 w-full bg-neutral-950
  before:absolute before:bottom-full before:bg-neutral-950 before:w-full before:h-32
  after:absolute after:top-full after:bg-neutral-950 after:w-full after:h-32"
>
  <div class="flex flex-col items-center gap-8 w-[min(1160px,100%)] md:gap-20">
    {features.map((feature, index) => <FeatureCard feature={feature} reverse={index % 2 !== 0} />)}
  </div>
</section>
