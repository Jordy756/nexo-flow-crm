---
import FeatureCard from "./FeatureCard.astro";
import { features } from "@data/data.json";
---

<section
  id="features"
  class="relative flex flex-col items-center gap-20 w-full bg-neutral-950 before:absolute before:bottom-full before:bg-neutral-950 before:w-full before:h-32 after:absolute after:top-full after:bg-neutral-950 after:w-full after:h-32"
>
  <div class="flex flex-col items-center gap-20 w-[min(1160px,100%)]">
    {features.map((feature, index) => <FeatureCard reverse={index % 2 !== 0} />)}
  </div>
</section>
