---
import type { FeatureGroup } from "@scripts/config/site.types";

interface Props {
  feature: FeatureGroup;
}

const { feature } = Astro.props;
---

<article class="surface-glass rounded-2xl p-6">
  <header>
    <h3 class="text-xl font-semibold text-slate-100">{feature.title}</h3>
    <p class="mt-2 text-sm text-cyan-200">{feature.subtitle}</p>
  </header>
  <ul class="mt-4 space-y-2 text-sm leading-relaxed text-slate-300" role="list">
    {feature.items.map((item) => <li>• {item}</li>)}
  </ul>
</article>
