---
import Link from "@components/ui/Link.astro";
import { Image } from "astro:assets";

interface Props {
  feature: {
    title: string;
    description: string;
    image: {
      url: string;
      alt: string;
    };
    cta: {
      href: string;
      target: string;
      label: string;
    };
  };
  reverse: boolean;
}

const { feature, reverse } = Astro.props;
const { title, description, image, cta } = feature;
---

<article class:list={["flex items-center justify-between flex-wrap gap-4 w-full", reverse ? "flex-row-reverse" : ""]}>
  <header class="flex flex-col items-start gap-2">
    <h3 class="text-3xl max-w-[20ch]">{title}</h3>
    <p class="max-w-[50ch] font-light mb-4">{description}</p>
    <Link href={cta.href} target={cta.target}>{cta.label}</Link>
  </header>
  <figure>
    <Image src={image.url} width={100} height={100} alt={image.alt} class="w-full h-auto max-w-125" />
  </figure>
</article>
