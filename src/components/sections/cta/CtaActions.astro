---
import Button from "@components/ui/Button.astro";
import type { SiteData } from "@scripts/config/site.types";

interface Props {
  cta: SiteData["cta"];
}

const { cta } = Astro.props;
---

<nav class="mt-8 flex flex-wrap items-center justify-center gap-3" aria-label="Acciones de cierre">
  <Button href={cta.primary.href} size="lg">{cta.primary.label}</Button>
  <Button href={cta.secondary.href} size="lg" variant="secondary">{cta.secondary.label}</Button>
</nav>
