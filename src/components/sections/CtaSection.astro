---
import Container from "@components/ui/Container.astro";
import Button from "@components/ui/Button.astro";
import type { SiteData } from "@scripts/config/site.types";

interface Props {
  data: SiteData;
}

const { data } = Astro.props;
---

<section id="cta" class="pb-8 pt-10 sm:pt-14">
  <Container>
    <div class="btn-glass-strong rounded-3xl px-6 py-10 text-center sm:px-12 sm:py-14">
      <h2 class="mx-auto max-w-3xl text-3xl font-semibold leading-tight text-white sm:text-4xl">
        {data.cta.title}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-sm leading-relaxed text-slate-200 sm:text-base">
        {data.cta.description}
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <Button href={data.cta.primary.href} size="lg">{data.cta.primary.label}</Button>
        <Button href={data.cta.secondary.href} size="lg" variant="secondary">
          {data.cta.secondary.label}
        </Button>
      </div>
    </div>
  </Container>
</section>
