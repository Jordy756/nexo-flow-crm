---
import Container from "@components/ui/Container.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import type { SiteData } from "@scripts/config/site.types";
import SegmentCard from "./SegmentCard.astro";

interface Props {
  data: SiteData;
}

const { data } = Astro.props;
---

<section id="segments" class="py-14 sm:py-20">
  <Container>
    <SectionHeading
      eyebrow="Segmentacion inteligente"
      title="Un mismo CRM, dos experiencias operativas"
      description="Construye workflows dedicados para leads activos y clientes en seguimiento sin perder visibilidad global."
    />

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {data.segments.map((segment) => <SegmentCard segment={segment} />)}
    </div>
  </Container>
</section>
