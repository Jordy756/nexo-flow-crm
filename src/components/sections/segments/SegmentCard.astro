---
import type { Segment } from "@scripts/config/site.types";

interface Props {
  segment: Segment;
}

const { segment } = Astro.props;
---

<article class="surface-glass rounded-2xl p-6">
  <header>
    <p class="text-xs uppercase tracking-[0.2em] text-cyan-300">{segment.name}</p>
    <p class="mt-3 text-sm leading-relaxed text-slate-300">{segment.description}</p>
  </header>
  <ul class="mt-4 space-y-2 text-sm text-slate-200" role="list">
    {segment.bullets.map((bullet) => <li>• {bullet}</li>)}
  </ul>
</article>
