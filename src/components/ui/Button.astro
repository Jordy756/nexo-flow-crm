---
interface Props {
  href: string;
  variant?: "primary" | "secondary";
  size?: "md" | "lg";
  class?: string;
}

const { href, variant = "primary", size = "md", class: className } = Astro.props;

const variants = {
  primary: "btn-glass-strong border-transparent text-white shadow-[0_20px_60px_-30px_rgba(132,91,255,0.85)]",
  secondary: "btn-glass border-white/20 text-white/90 hover:border-violet-300/50",
};

const sizes = {
  md: "px-5 py-2.5 text-sm",
  lg: "px-6 py-3 text-base",
};
---

<a
  href={href}
  class:list={[
    "inline-flex items-center justify-center rounded-xl font-semibold tracking-[0.01em] transition duration-300 hover:-translate-y-0.5",
    variants[variant],
    sizes[size],
    className,
  ]}
>
  <slot />
</a>
