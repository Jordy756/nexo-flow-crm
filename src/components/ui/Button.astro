---
import ArrowOutwardIcon from "@components/icons/ArrowOutward.astro";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"button"> {
  variant?: "primary" | "secondary";
}

const { variant = "primary", class: className, ...rest } = Astro.props;
---

<button
  class:list={[
    "flex items-center justify-center gap-3 py-2 pr-2 pl-4 border rounded-full font-medium text-base cursor-pointer whitespace-nowrap transition-opacity hover:opacity-80",
    `btn-${variant}`,
    className,
  ]}
  {...rest}
>
  <slot />
  <div class:list={["p-1 rounded-full flex", variant === "primary" && "bg-neutral-950"]}>
    <ArrowOutwardIcon width={20} class="text-neutral-50" />
  </div>
</button>
